# ─────────────────────────────────────────────────────────────────────────────
# ObservabilityStack — example environment variables
# ─────────────────────────────────────────────────────────────────────────────
# The infrastructure itself (docker compose) runs with sane defaults and does
# NOT read this file. These are the variables YOUR app sets so it emits OTLP
# telemetry into the stack. Copy the ones you need into your app's own .env
# (or export them) — full per-language guide: docs/CONNECT.md.

# Apps running on the host (npm run dev, python app.py, …):
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=my-app                            # unique per app — how you filter later
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev

# Apps inside the same docker network use the service name instead:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Optional: faster metrics for local dev (default is 60s)
#   OTEL_METRIC_EXPORT_INTERVAL=10000
